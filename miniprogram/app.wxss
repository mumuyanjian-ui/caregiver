page {
  background:
    radial-gradient(circle at top left, rgba(34, 211, 238, 0.14), transparent 30%),
    radial-gradient(circle at top right, rgba(15, 118, 110, 0.2), transparent 34%),
    linear-gradient(180deg, #f4fbfb 0%, #edf8f7 48%, #e3f0ef 100%);
  color: #14323a;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
input,
textarea,
button,
picker,
scroll-view,
navigator {
  box-sizing: border-box;
}

.page-shell {
  min-height: 100vh;
  width: 100%;
  padding: 24rpx 24rpx 140rpx;
  overflow-x: hidden;
}

.panel {
  width: 100%;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(17, 94, 89, 0.1);
  border-radius: 32rpx;
  box-shadow: 0 24rpx 60rpx rgba(27, 84, 87, 0.08);
}

.eyebrow {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: #0f766e;
}

.section-title {
  margin-top: 10rpx;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.25;
  color: #14323a;
}

.muted {
  color: #60767d;
  line-height: 1.72;
}

.chip {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(13, 148, 136, 0.1);
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 600;
}

.primary-btn {
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx 30rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #0ea5a4 0%, #0f766e 58%, #155e75 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 30rpx rgba(15, 118, 110, 0.2);
}

.secondary-btn {
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx 30rpx;
  border-radius: 999rpx;
  background: rgba(14, 165, 164, 0.1);
  color: #0f766e;
  border: 1rpx solid rgba(14, 165, 164, 0.18);
  font-size: 28rpx;
  font-weight: 700;
}

