page {
  background:
    radial-gradient(circle at top left, rgba(217, 119, 6, 0.16), transparent 28%),
    radial-gradient(circle at top right, rgba(15, 118, 110, 0.2), transparent 32%),
    linear-gradient(180deg, #fdf8ef 0%, #f7f2e8 55%, #efe4d1 100%);
  color: #1f2a24;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-shell {
  padding: 24rpx 24rpx 40rpx;
}

.panel {
  background: rgba(255, 252, 247, 0.92);
  border: 1rpx solid rgba(44, 66, 55, 0.12);
  border-radius: 28rpx;
  box-shadow: 0 20rpx 48rpx rgba(51, 58, 53, 0.08);
}

.eyebrow {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: #0f766e;
}

.section-title {
  margin-top: 8rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2a24;
}

.muted {
  color: #5f6d66;
  line-height: 1.7;
}

.chip {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(15, 118, 110, 0.1);
  color: #0b5254;
  font-size: 24rpx;
}

.primary-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #0f766e 0%, #0b5254 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.secondary-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(15, 118, 110, 0.1);
  color: #0b5254;
  font-size: 28rpx;
  font-weight: 700;
}
