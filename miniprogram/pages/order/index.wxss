.emergency-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, #0e7490 0%, #0f766e 100%);
  color: #fff;
  font-weight: 700;
  box-shadow: 0 16rpx 30rpx rgba(14, 116, 144, 0.18);
}

.emergency-icon {
  font-size: 32rpx;
}

.emergency-text {
  font-size: 30rpx;
}

.order-head,
.form-panel,
.preview-panel,
.progress-panel {
  padding: 26rpx;
  margin-bottom: 18rpx;
}

.order-head {
  background: linear-gradient(145deg, rgba(247, 255, 255, 0.95), rgba(239, 251, 249, 0.94));
}

.field {
  margin-bottom: 22rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #15343b;
}

.field input,
.picker,
.field textarea {
  width: 100%;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #f8fcfc;
  border: 1rpx solid rgba(14, 116, 144, 0.08);
  color: #14323a;
}

.field textarea {
  min-height: 180rpx;
}

.switch-row {
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(248, 253, 253, 0.95);
  border: 1rpx solid rgba(13, 148, 136, 0.08);
}

.submit-btn {
  width: 100%;
  margin-top: 8rpx;
}

.preview-list {
  display: grid;
  gap: 12rpx;
  margin-top: 18rpx;
}

.preview-item {
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(248, 253, 253, 0.95);
  border: 1rpx solid rgba(13, 148, 136, 0.08);
  color: #60767d;
}

.sop-grid {
  display: grid;
  gap: 14rpx;
  margin-top: 22rpx;
}

.sop-card {
  padding: 20rpx;
  border-radius: 22rpx;
  background: rgba(248, 253, 253, 0.95);
  border: 1rpx solid rgba(13, 148, 136, 0.08);
}

.sop-card.active {
  background: linear-gradient(145deg, rgba(221, 250, 246, 0.95), rgba(236, 254, 255, 0.96));
  border-color: rgba(13, 148, 136, 0.2);
}

.sop-index {
  width: 46rpx;
  height: 46rpx;
  line-height: 46rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(20, 184, 166, 0.14);
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 700;
}

.sop-title {
  margin-top: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #14323a;
}

.progress-panel {
  background: linear-gradient(145deg, rgba(236, 254, 255, 0.95), rgba(236, 253, 245, 0.92));
}

.progress-timeline {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 20rpx;
}

.progress-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  position: relative;
}

.progress-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #cbd5da;
  border: 4rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  z-index: 1;
}

.progress-item.active .progress-dot {
  background: #0f766e;
}

.progress-item.current .progress-dot {
  background: #0891b2;
  box-shadow: 0 0 0 8rpx rgba(14, 165, 164, 0.18);
}

.progress-line {
  position: absolute;
  left: 10rpx;
  top: 32rpx;
  width: 4rpx;
  height: 40rpx;
  background: #d6e1e3;
}

.progress-item.active .progress-line {
  background: linear-gradient(180deg, #0891b2 0%, #0f766e 100%);
}

.progress-label {
  font-size: 26rpx;
  color: #61797f;
}

.progress-item.active .progress-label,
.progress-item.current .progress-label {
  color: #0f766e;
  font-weight: 700;
}

.progress-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.progress-btn {
  flex: 1;
  padding: 20rpx;
  background: linear-gradient(135deg, #0891b2 0%, #0f766e 100%);
  color: #fff;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
}

.progress-btn.reset {
  background: #7b9198;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 70rpx 40rpx;
  margin-top: 10rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 28rpx;
  border: 2rpx dashed rgba(13, 148, 136, 0.22);
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #698188;
  text-align: center;
}
