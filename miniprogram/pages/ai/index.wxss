.ai-head,
.ai-form,
.ai-result,
.ai-tips {
  padding: 26rpx;
  margin-bottom: 18rpx;
}

.ai-head {
  background: linear-gradient(145deg, rgba(240, 253, 250, 0.95), rgba(236, 254, 255, 0.94));
}

.cloud-tip {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.cloud-tip.ready {
  background: rgba(20, 184, 166, 0.1);
  color: #0f766e;
}

.cloud-tip.warning {
  background: rgba(245, 158, 11, 0.12);
  color: #b45309;
}

.scene-scroll {
  white-space: nowrap;
  margin-bottom: 18rpx;
}

.scene-row {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 8rpx;
}

.scene-chip {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #5d757b;
  border: 1rpx solid rgba(13, 148, 136, 0.1);
}

.scene-chip.active {
  background: linear-gradient(135deg, #14b8a6 0%, #0f766e 100%);
  color: #fff;
  box-shadow: 0 12rpx 24rpx rgba(15, 118, 110, 0.18);
}

.field {
  margin-bottom: 22rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #15343b;
}

.field input,
.picker {
  width: 100%;
  display: flex;
  align-items: center;
  height: 92rpx;
  padding: 0 20rpx;
  line-height: 92rpx;
  border-radius: 20rpx;
  background: #f8fcfc;
  border: 1rpx solid rgba(14, 116, 144, 0.08);
  color: #14323a;
}

.field textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #f8fcfc;
  border: 1rpx solid rgba(14, 116, 144, 0.08);
  color: #14323a;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 92rpx;
}

.result-card,
.tip-card {
  margin-top: 16rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: rgba(248, 253, 253, 0.95);
  border: 1rpx solid rgba(13, 148, 136, 0.08);
}

.result-text {
  color: #27464b;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-word;
}

.tip-title {
  display: block;
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #15343b;
}
