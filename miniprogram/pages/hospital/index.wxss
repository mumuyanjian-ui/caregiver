.top-bar,
.search-box,
.hospital-summary,
.task-panel {
  padding: 26rpx;
  margin-bottom: 18rpx;
}

.top-bar {
  background: linear-gradient(145deg, rgba(247, 255, 255, 0.95), rgba(239, 251, 249, 0.94));
}

.mini-cta {
  margin-top: 20rpx;
}

.search-box {
  position: sticky;
  top: 0;
  z-index: 60;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(12rpx);
}

.search-box input {
  width: 100%;
  display: block;
  height: 92rpx;
  padding: 0 108rpx 0 22rpx;
  line-height: 92rpx;
  border-radius: 20rpx;
  background: #f7fcfc;
  border: 1rpx solid rgba(14, 116, 144, 0.08);
  color: #14323a;
}

.search-clear {
  position: absolute;
  right: 22rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 24rpx;
  font-weight: 700;
  color: #0891b2;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(34, 211, 238, 0.12);
}

.hospital-scroll,
.task-scroll {
  white-space: nowrap;
  margin-bottom: 18rpx;
}

.hospital-chip-row,
.task-row {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 8rpx;
}

.hospital-chip,
.task-tab {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #5d757b;
  border: 1rpx solid rgba(13, 148, 136, 0.1);
}

.hospital-chip.active,
.task-tab.active {
  background: linear-gradient(135deg, #14b8a6 0%, #0f766e 100%);
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(15, 118, 110, 0.18);
}

.hospital-summary {
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.96), rgba(239, 251, 249, 0.94));
}

.summary-title,
.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #15343b;
}

.detail-badge {
  display: inline-block;
  margin-top: 16rpx;
  padding: 10rpx 18rpx;
  background: rgba(14, 165, 164, 0.12);
  color: #0f766e;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.hospital-summary .muted {
  display: block;
  margin-top: 10rpx;
  word-break: break-all;
}

.task-panel {
  margin-bottom: 120rpx;
}

.task-source {
  margin-top: 8rpx;
}

.step-list {
  display: grid;
  gap: 16rpx;
  margin-top: 20rpx;
}

.step-card {
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(248, 253, 253, 0.95);
  border: 1rpx solid rgba(13, 148, 136, 0.1);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.6);
}

.step-top {
  display: flex;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.step-badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(20, 184, 166, 0.12);
  color: #0f766e;
  font-size: 22rpx;
  font-weight: 700;
}

.step-badge.light {
  background: rgba(14, 116, 144, 0.08);
  color: #155e75;
}

.step-card .muted {
  display: block;
  margin-top: 8rpx;
  word-break: break-all;
}

.step-card .notice {
  color: #0e7490;
  font-weight: 600;
}

.empty-steps {
  padding: 40rpx;
  text-align: center;
  color: #6c848b;
  font-size: 28rpx;
}

.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx 28rpx;
  background: linear-gradient(180deg, rgba(239, 248, 248, 0.25), rgba(255, 255, 255, 0.98) 35%);
  box-shadow: 0 -8rpx 30rpx rgba(21, 94, 117, 0.06);
  z-index: 100;
}

.action-btn {
  width: 100%;
  box-sizing: border-box;
  padding: 24rpx;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #0891b2 0%, #0f766e 100%);
  color: #fff;
  box-shadow: 0 16rpx 30rpx rgba(14, 116, 144, 0.2);
}

