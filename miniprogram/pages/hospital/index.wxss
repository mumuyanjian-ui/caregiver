.top-bar,
.search-box,
.hospital-summary,
.task-panel {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.mini-cta {
  margin-top: 18rpx;
}

.search-box {
  position: relative;
}

.search-box input {
  width: 100%;
  padding: 18rpx 50rpx 18rpx 20rpx;
  border-radius: 18rpx;
  background: #ffffff;
}

.search-clear {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.hospital-scroll,
.task-scroll {
  white-space: nowrap;
  margin-bottom: 18rpx;
}

.hospital-chip-row,
.task-row {
  display: inline-flex;
  gap: 12rpx;
}

.hospital-chip,
.task-tab {
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  color: #5f6d66;
  border: 1rpx solid rgba(44, 66, 55, 0.08);
}

.hospital-chip.active,
.task-tab.active {
  background: #0b5254;
  color: #ffffff;
}

.summary-title,
.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2a24;
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.peak-badge {
  padding: 8rpx 16rpx;
  background: rgba(231, 76, 60, 0.1);
  color: #e74c3c;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.detail-badge {
  display: inline-block;
  margin-top: 16rpx;
  padding: 8rpx 16rpx;
  background: rgba(15, 118, 110, 0.1);
  color: #0f766e;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.hospital-summary .muted {
  display: block;
  margin-top: 10rpx;
}

.task-source {
  margin-top: 8rpx;
}

/* 加载状态 */
.loading-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.loading-spinner-small {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #e5e7eb;
  border-top-color: #0f766e;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 步骤状态 */
.step-list {
  display: grid;
  gap: 16rpx;
  margin-top: 20rpx;
}

.step-card {
  padding: 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.75);
  border: 1rpx solid rgba(44, 66, 55, 0.08);
  transition: all 0.3s ease;
}

.step-card.completed {
  background: rgba(15, 118, 110, 0.08);
  border-color: rgba(15, 118, 110, 0.2);
}

.step-top {
  display: flex;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.step-badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(15, 118, 110, 0.12);
  color: #0b5254;
  font-size: 22rpx;
}

.step-badge.done {
  background: #0f766e;
  color: #fff;
}

.step-badge.light {
  background: rgba(31, 42, 36, 0.06);
}

.step-card .muted {
  display: block;
  margin-top: 8rpx;
}

.step-card .notice {
  color: #d97706;
  font-weight: 600;
}

/* 空步骤提示 */
.empty-steps {
  padding: 40rpx;
  text-align: center;
  color: #6b7280;
  font-size: 28rpx;
}

/* 底部操作按钮 */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.action-btn {
  width: 100%;
  padding: 24rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #0f766e 0%, #0b5254 100%);
  color: #fff;
}
