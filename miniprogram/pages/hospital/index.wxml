<view class="page-shell">
  <view class="top-bar panel">
    <view>
      <view class="eyebrow">潮汕探索</view>
      <view class="section-title">先选地点，再看玩法模块</view>
    </view>
    <view class="primary-btn mini-cta" bindtap="goPlanPage">做我的行程</view>
  </view>

  <view class="search-box panel">
    <input placeholder="搜索古城、海岛、美食、亲子路线" bindinput="onSearchInput" value="{{searchKeyword}}" />
    <view class="search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">清除</view>
  </view>

  <scroll-view class="hospital-scroll" scroll-x="true" show-scrollbar="false">
    <view class="hospital-chip-row">
      <view
        class="hospital-chip {{item.active ? 'active' : ''}}"
        wx:for="{{filteredDestinations}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="selectDestination"
      >
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <view class="hospital-summary panel">
    <view class="summary-title">{{activeDestination.name}}</view>
    <view class="chip">{{activeDestination.region}} · {{activeDestination.tag}}</view>
    <view class="muted">{{activeDestination.highlight}}</view>
    <view class="muted">适合人群：{{activeDestination.bestFor}}</view>
    <view class="muted">旅行气质：{{activeDestination.vibe}}</view>
    <view class="muted">可重点安排：{{activeDestination.foodsText}}</view>
    <view class="detail-badge">推荐停留：{{activeDestination.stay}}</view>
  </view>

  <scroll-view class="task-scroll" scroll-x="true" show-scrollbar="false">
    <view class="task-row">
      <view
        class="task-tab {{item.active ? 'active' : ''}}"
        wx:for="{{routeTabs}}"
        wx:key="key"
        data-tab="{{item.key}}"
        bindtap="selectTab"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <view class="task-panel panel">
    <view class="card-title">{{activeRouteLabel}}</view>
    <view class="muted">{{activeRouteDescription}}</view>

    <view class="step-list">
      <view class="step-card" wx:for="{{steps}}" wx:key="title">
        <view class="step-top">
          <text class="step-badge">{{activeRouteLabel}}</text>
          <text class="step-badge light">{{item.orderText}}</text>
        </view>
        <view class="card-title">{{item.title}}</view>
        <view class="muted">地点：{{item.location}}</view>
        <view class="muted">安排：{{item.action}}</view>
        <view class="muted notice">{{item.notice}}</view>
      </view>
    </view>
  </view>

  <view class="bottom-action">
    <button class="action-btn primary" bindtap="goPlanPage">生成这站的 AI 行程</button>
  </view>
</view>
