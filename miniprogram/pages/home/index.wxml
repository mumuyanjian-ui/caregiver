<view class="page-shell">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索潮州古城、南澳岛、小公园..." bindinput="onSearchInput" value="{{searchKeyword}}" />
    <view class="search-btn" bindtap="clearSearch">{{searchKeyword ? '清除' : '探索'}}</view>
  </view>

  <view class="loading-panel" wx:if="{{isLoading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在整理潮汕灵感...</text>
  </view>

  <view wx:else>
    <view class="operation-banner panel" bindtap="goExplorePage">
      <view class="banner-top">
        <view class="banner-tag">{{operationBanner.tag}}</view>
        <view class="banner-link">{{operationBanner.cta}}</view>
      </view>
      <view class="banner-title">{{operationBanner.title}}</view>
      <view class="banner-desc">{{operationBanner.desc}}</view>
      <view class="banner-stats">
        <text class="banner-stat" wx:for="{{operationBanner.stats}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="banner-glow banner-glow-one"></view>
      <view class="banner-glow banner-glow-two"></view>
    </view>

    <view class="hero panel">
      <view class="eyebrow">潮汕 AI 文旅助手</view>
      <view class="hero-title">AI游潮汕</view>
      <view class="hero-desc muted">围绕潮州、汕头、揭阳做一款会给路线、会推美食、会讲文化的旅行应用。</view>

      <view class="metrics">
        <view class="metric-card">
          <text class="metric-title">目的地清晰</text>
          <text class="muted">把古城、海岛、老街和亲子玩法整理成可直接选择的卡片。</text>
        </view>
        <view class="metric-card">
          <text class="metric-title">AI 更实用</text>
          <text class="muted">可以直接生成 1 到 3 天路线、美食建议和文化解读。</text>
        </view>
        <view class="metric-card">
          <text class="metric-title">行程能落地</text>
          <text class="muted">把偏好写进计划单，后续可继续补云端存储和分享。</text>
        </view>
      </view>

      <view class="hero-actions">
        <view class="primary-btn" bindtap="goExplorePage">先看潮汕目的地</view>
        <view class="secondary-btn" bindtap="goPlanPage">生成行程</view>
      </view>
    </view>

    <view class="strip-list">
      <view class="strip-card panel">
        <text class="strip-label">旅行气质</text>
        <text class="strip-title">古城慢游、海岛放空、老街觅食三条线并存</text>
      </view>
      <view class="strip-card panel">
        <text class="strip-label">使用方式</text>
        <text class="strip-title">先选地点，再让 AI 帮你补路线和美食细节</text>
      </view>
    </view>

    <view class="quick-grid">
      <view class="quick-card panel" wx:for="{{quickActions}}" wx:key="key" data-key="{{item.key}}" bindtap="handleQuickTap">
        <text class="quick-label">{{item.title}}</text>
        <text class="quick-title">{{item.subtitle}}</text>
        <text class="muted">{{item.desc}}</text>
      </view>
    </view>

    <view class="section">
      <view class="eyebrow">热门目的地</view>
      <view class="section-title">先从这几站开始</view>
      <view class="hospital-list">
        <view class="hospital-card panel" wx:for="{{filteredDestinations}}" wx:key="id" data-id="{{item.id}}" bindtap="goDestinationDetail">
          <view class="card-title">{{item.name}}</view>
          <view class="muted">{{item.region}} · {{item.tag}}</view>
          <view class="muted">{{item.highlight}}</view>
          <view class="muted">适合：{{item.bestFor}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="eyebrow">旅行主题</view>
      <view class="section-title">按玩法选更快</view>
      <view class="department-list">
        <view class="department-card panel" wx:for="{{travelThemes}}" wx:key="key">
          <view class="card-title">{{item.title}}</view>
          <view class="muted">{{item.subtitle}}</view>
          <view class="muted">{{item.suggestion}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="back-to-top" wx:if="{{showBackToTop}}" bindtap="scrollToTop">↑</view>
</view>

