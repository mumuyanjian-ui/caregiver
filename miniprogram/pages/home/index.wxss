.search-bar {
  position: sticky;
  top: 0;
  z-index: 60;
  display: flex;
  gap: 16rpx;
  padding: 12rpx 0 20rpx;
  width: 100%;
  background: linear-gradient(180deg, rgba(244, 251, 251, 0.98) 0%, rgba(244, 251, 251, 0.92) 78%, rgba(244, 251, 251, 0) 100%);
  backdrop-filter: blur(10rpx);
}

.search-input {
  flex: 1;
  min-width: 0;
  width: 0;
  height: 88rpx;
  padding: 0 24rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(14, 116, 144, 0.08);
  font-size: 28rpx;
  color: #14323a;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.6);
}

.search-btn {
  flex-shrink: 0;
  height: 88rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #0891b2 0%, #0f766e 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.loading-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 5rpx solid rgba(125, 211, 252, 0.3);
  border-top-color: #0891b2;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 18rpx;
  font-size: 26rpx;
  color: #64818a;
}

.search-result-tip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(14, 165, 164, 0.1);
  font-size: 26rpx;
  color: #0f766e;
}

.clear-search {
  font-weight: 700;
}

.empty-search {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 40rpx;
  margin: 20rpx 0 0;
  background: rgba(255, 255, 255, 0.72);
  border-radius: 28rpx;
  border: 2rpx dashed rgba(14, 165, 164, 0.24);
  font-size: 28rpx;
  color: #64818a;
}

.empty-search .empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.back-to-top {
  position: fixed;
  right: 30rpx;
  bottom: 36rpx;
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #14b8a6 0%, #0f766e 100%);
  color: #fff;
  border-radius: 50%;
  font-size: 40rpx;
  box-shadow: 0 14rpx 28rpx rgba(15, 118, 110, 0.24);
  z-index: 999;
}

.operation-banner {
  position: relative;
  overflow: hidden;
  margin-bottom: 18rpx;
  padding: 30rpx 28rpx 34rpx;
  background:
    linear-gradient(135deg, rgba(7, 89, 133, 0.95) 0%, rgba(13, 148, 136, 0.96) 55%, rgba(20, 184, 166, 0.92) 100%);
  color: #ffffff;
}

.banner-top {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.banner-tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.banner-link {
  font-size: 24rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.92);
}

.banner-title {
  position: relative;
  z-index: 2;
  margin-top: 24rpx;
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1.12;
}

.banner-desc {
  position: relative;
  z-index: 2;
  margin-top: 16rpx;
  max-width: 88%;
  font-size: 27rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.86);
}

.banner-stats {
  position: relative;
  z-index: 2;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 24rpx;
}

.banner-stat {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  font-size: 24rpx;
}

.banner-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(4rpx);
}

.banner-glow-one {
  right: -40rpx;
  top: -30rpx;
  width: 220rpx;
  height: 220rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.32), transparent 66%);
}

.banner-glow-two {
  right: 110rpx;
  bottom: -60rpx;
  width: 180rpx;
  height: 180rpx;
  background: radial-gradient(circle, rgba(165, 243, 252, 0.24), transparent 70%);
}

.hero {
  position: relative;
  overflow: hidden;
  padding: 36rpx 32rpx;
  background:
    linear-gradient(145deg, rgba(236, 254, 255, 0.96) 0%, rgba(240, 253, 250, 0.94) 100%);
}

.hero::after {
  content: "";
  position: absolute;
  right: -50rpx;
  top: -40rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(34, 211, 238, 0.18), transparent 68%);
}

.hero-title {
  margin-top: 14rpx;
  font-size: 68rpx;
  font-weight: 800;
  line-height: 1.04;
  color: #0f3440;
}

.hero-desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  max-width: 92%;
}

.metrics {
  margin-top: 26rpx;
  display: grid;
  gap: 16rpx;
}

.metric-card {
  padding: 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(13, 148, 136, 0.1);
}

.metric-title,
.card-title,
.quick-title,
.strip-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #17363d;
}

.hero-actions {
  margin-top: 26rpx;
  display: flex;
  gap: 16rpx;
  width: 100%;
}

.hero-actions .primary-btn,
.hero-actions .secondary-btn {
  flex: 1;
  min-width: 0;
}

.strip-list,
.hospital-list,
.department-list {
  display: grid;
  gap: 16rpx;
  margin-top: 18rpx;
}

.strip-card,
.hospital-card,
.department-card,
.quick-card {
  padding: 24rpx;
}

.strip-card {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.9), rgba(239, 250, 250, 0.94));
}

.strip-label,
.quick-label {
  display: block;
  font-size: 24rpx;
  color: #0891b2;
  font-weight: 700;
}

.quick-grid {
  display: grid;
  gap: 16rpx;
  margin-top: 20rpx;
}

.quick-card {
  position: relative;
  overflow: hidden;
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.94), rgba(237, 249, 249, 0.96));
}

.quick-card::after {
  content: "";
  position: absolute;
  right: -30rpx;
  bottom: -30rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(20, 184, 166, 0.1), transparent 70%);
}

.quick-card .quick-title {
  margin-top: 10rpx;
}

.quick-card .muted,
.hospital-card .muted,
.department-card .muted {
  display: block;
  margin-top: 8rpx;
  word-break: break-all;
}

.hospital-card,
.department-card {
  background: rgba(255, 255, 255, 0.9);
}

.section {
  margin-top: 30rpx;
}

